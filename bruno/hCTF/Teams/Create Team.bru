meta {
  name: Create Team
  type: http
  seq: 3
}

post {
  url: {{host}}/api/collections/teams/records
  body: json
  auth: bearer
}

auth:bearer {
  token: {{userToken}}
}

body:json {
  {
    "name": "{{team_name}}",
    "description": "{{team_description}}"
  }
}

vars:pre-request {
  team_name: Test Team 4
  team_description: This is the test team 4
}
